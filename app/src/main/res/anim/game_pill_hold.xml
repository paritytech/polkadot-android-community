<?xml version="1.0" encoding="utf-8"?>
<!--
  No-op animation that keeps the underlying destination stationary while the game play fragment
  slides in over it. Duration matches game_pill_slide_up/down so the Android nav component waits
  the full transition before swapping fragment visibility.
-->
<translate xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="@android:integer/config_shortAnimTime"
    android:fromYDelta="0%p"
    android:toYDelta="0%p" />
