<?xml version="1.0" encoding="utf-8"?>
<!--
  Enter animation when the user taps the weekly-game pill. The game play fragment slides up
  from the bottom of the window, mimicking a modal sheet. Paired with game_pill_hold.xml on
  the outgoing destination so the screen underneath appears stationary during the transition.
-->
<translate xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="@android:integer/config_shortAnimTime"
    android:fromYDelta="100%p"
    android:interpolator="@android:interpolator/fast_out_slow_in"
    android:toYDelta="0%p" />
