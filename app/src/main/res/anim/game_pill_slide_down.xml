<?xml version="1.0" encoding="utf-8"?>
<!--
  Pop-exit animation when the user collapses the game via the chevron-down button or system back.
  The game play fragment slides down off the bottom of the window, revealing the previously
  visible destination. The pill fades in from the overlay shortly after (see AnimatedVisibility
  in GamePillOverlay).
-->
<translate xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="@android:integer/config_shortAnimTime"
    android:fromYDelta="0%p"
    android:interpolator="@android:interpolator/fast_out_slow_in"
    android:toYDelta="100%p" />
