<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="io.paritytech.polkadotapp.feature_splash_impl.presentation.SplashFragment"
        android:label="SplashFragment" />

    <fragment
        android:id="@+id/chatFeedFragment"
        android:name="io.paritytech.polkadotapp.feature_chats_impl.presentation.feed.ChatFeedFragment"
        android:label="ChatFeedFragment" />

    <fragment
        android:id="@+id/addContactFragment"
        android:name="io.paritytech.polkadotapp.feature_chats_impl.presentation.search.AddContactFragment"
        android:label="AddContactFragment" />

    <fragment
        android:id="@+id/CurrencyFragment"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.currency.CurrencyFragment"
        android:label="CurrencyFragment" />

    <fragment
        android:id="@+id/blockedUsersFragment"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.blockedUsers.BlockedUsersFragment"
        android:label="BlockedUsersFragment" />

    <fragment
        android:id="@+id/linkedDevicesFragment"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.linkedDevices.LinkedDevicesFragment"
        android:label="LinkedDevicesFragment" />

    <fragment
        android:id="@+id/deviceDetailsFragment"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.deviceDetails.DeviceDetailsFragment"
        android:label="DeviceDetailsFragment" />

    <fragment
        android:id="@+id/forceReclaimFragment"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.forceReclaim.ForceReclaimFragment"
        android:label="ForceReclaimFragment" />

    <fragment
        android:id="@+id/LanguageFragment"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.language.LanguageFragment"
        android:label="LanguageFragment" />

    <fragment
        android:id="@+id/ThemeFragment"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.theme.ThemeFragment"
        android:label="ThemeFragment" />

    <fragment
        android:id="@+id/videoGameNotificationsFragment"
        android:name="io.paritytech.polkadotapp.feature_videogame_impl.presentation.notifications.VideoGameNotificationsFragment"
        android:label="VideoGameNotificationsFragment" />

    <fragment
        android:id="@+id/debugMenuFragment"
        android:name="io.paritytech.polkadotapp.app.root.presentation.debug.DebugMenuFragment"
        android:label="DebugMenuFragment" />

    <fragment
        android:id="@+id/productBotManagementFragment"
        android:name="io.paritytech.polkadotapp.feature_products_impl.presentation.productBotManagement.ProductBotManagementFragment"
        android:label="ProductBotManagementFragment" />

    <fragment
        android:id="@+id/spaBrowserFragment"
        android:name="io.paritytech.polkadotapp.feature_products_impl.presentation.spaBrowser.SpaBrowserFragment"
        android:label="SpaBrowserFragment" />

    <dialog
        android:id="@+id/pairRequestBottomSheet"
        android:name="io.paritytech.polkadotapp.feature_sso_impl.presentation.pairRequest.PairRequestBottomSheet"
        android:label="PairRequestBottomSheet" />

    <dialog
        android:id="@+id/transactionSignBottomSheet"
        android:name="io.paritytech.polkadotapp.feature_products_impl.presentation.signTransaction.TransactionSignBottomSheet"
        android:label="TransactionSignBottomSheet" />

    <dialog
        android:id="@+id/permissionPromptBottomSheet"
        android:name="io.paritytech.polkadotapp.feature_products_impl.presentation.permissionPrompt.PermissionPromptBottomSheet"
        android:label="PermissionPromptBottomSheet" />

    <dialog
        android:id="@+id/paymentRequestBottomSheet"
        android:name="io.paritytech.polkadotapp.feature_products_impl.presentation.paymentRequest.PaymentRequestBottomSheet"
        android:label="PaymentRequestBottomSheet" />

    <dialog
        android:id="@+id/topUpRequestBottomSheet"
        android:name="io.paritytech.polkadotapp.feature_products_impl.presentation.topUpRequest.TopUpRequestBottomSheet"
        android:label="TopUpRequestBottomSheet" />

    <dialog
        android:id="@+id/resourceAllocationRequestBottomSheet"
        android:name="io.paritytech.polkadotapp.feature_products_impl.presentation.resourceAllocationRequest.ResourceAllocationRequestBottomSheet"
        android:label="ResourceAllocationRequestBottomSheet" />

    <fragment
        android:id="@+id/chatWithPlayersFragment"
        android:name="io.paritytech.polkadotapp.feature_videogame_impl.presentation.chatWithPlayers.ChatWithPlayersFragment"
        android:label="ChatWithPlayersFragment" />

    <fragment
        android:id="@+id/gameResultsFragment"
        android:name="io.paritytech.polkadotapp.feature_videogame_impl.presentation.gameResults.GameResultsFragment"
        android:label="GameResultsFragment" />

    <fragment
        android:id="@+id/collectiblesFragment"
        android:name="io.paritytech.polkadotapp.feature_videogame_impl.presentation.collectibles.CollectiblesFragment"
        android:label="CollectiblesFragment" />

    <fragment
        android:id="@+id/upgradeUsernameFragment"
        android:name="io.paritytech.polkadotapp.feature_upgrade_username_impl.presentation.upgrade.UpgradeUsernameFragment"
        android:label="UpgradeUsernameFragment" />

    <fragment
        android:id="@+id/chatRequestsListFragment"
        android:name="io.paritytech.polkadotapp.feature_chats_impl.presentation.chatRequestsList.ChatRequestsListFragment"
        android:label="ChatRequestsListFragment" />

    <fragment
        android:id="@+id/evidenceDetailFragment"
        android:name="io.paritytech.polkadotapp.feature_mobrules_impl.presentation.evidenceDetail.MediaEvidenceDetailFragment"
        android:label="MediaEvidenceDetailFragment" />


    <fragment
        android:id="@+id/themeSelectionOnboarding"
        android:name="io.paritytech.polkadotapp.feature_settings_impl.presentation.theme.ThemeFragmentOnboarding"
        android:label="ThemeFragmentOnboarding" />

    <action
        android:id="@+id/action_global_to_main_graph"
        app:destination="@id/main_graph"
        app:popUpTo="@id/root_nav_graph"
        app:popUpToInclusive="true" />

    <action
        android:id="@+id/action_global_to_claim_username_graph"
        app:destination="@id/claim_username_graph"
        app:popUpTo="@id/root_nav_graph"
        app:popUpToInclusive="true" />

    <action
        android:id="@+id/action_global_to_w3s_spa_graph"
        app:destination="@id/w3s_spa_graph"
        app:popUpTo="@id/root_nav_graph"
        app:popUpToInclusive="true" />

    <action
        android:id="@+id/action_global_to_w3s_ended_graph"
        app:destination="@id/w3s_ended_graph"
        app:popUpTo="@id/root_nav_graph"
        app:popUpToInclusive="true" />

    <action
        android:id="@+id/action_global_to_chatFeedFragment"
        app:destination="@id/chatFeedFragment"
        app:popUpTo="@id/mainFragment" />

    <action
        android:id="@+id/action_global_to_addContactFragment"
        app:destination="@id/addContactFragment" />

    <action
        android:id="@+id/action_global_to_chatRequestsListFragment"
        app:destination="@id/chatRequestsListFragment" />

    <action
        android:id="@+id/action_global_to_send_contact_payment_graph"
        app:destination="@id/send_contact_payment_graph" />

    <action
        android:id="@+id/action_global_to_send_enter_amount_graph"
        app:destination="@id/send_enter_amount_graph" />

    <action
        android:id="@+id/action_global_to_theme_onboarding"
        app:destination="@+id/themeSelectionOnboarding"
        app:popUpTo="@id/root_nav_graph"
        app:popUpToInclusive="true" />

    <action
        android:id="@+id/action_global_to_video_game_play_graph"
        app:destination="@id/video_game_play_graph"
        app:enterAnim="@anim/game_pill_slide_up"
        app:exitAnim="@anim/game_pill_hold"
        app:popEnterAnim="@anim/game_pill_hold"
        app:popExitAnim="@anim/game_pill_slide_down" />

    <action
        android:id="@+id/action_global_to_gameResultsFragment"
        app:destination="@id/gameResultsFragment"
        app:enterAnim="@anim/prize_slide_in_bottom"
        app:exitAnim="@anim/no_op"
        app:popEnterAnim="@anim/no_op"
        app:popExitAnim="@anim/prize_slide_out_bottom" />

    <action
        android:id="@+id/action_global_to_collectiblesFragment"
        app:destination="@id/collectiblesFragment"
        app:enterAnim="@anim/prize_slide_in_bottom"
        app:exitAnim="@anim/no_op"
        app:popEnterAnim="@anim/no_op"
        app:popExitAnim="@anim/prize_slide_out_bottom" />

    <action
        android:id="@+id/action_global_to_upgradeUsernameFragment"
        app:destination="@id/upgradeUsernameFragment" />

    <action
        android:id="@+id/action_global_to_video_game_notifications"
        app:destination="@id/videoGameNotificationsFragment" />

    <action
        android:id="@+id/action_global_to_backup_graph"
        app:destination="@id/backup_graph" />

    <action
        android:id="@+id/action_global_to_debug_menu"
        app:destination="@id/debugMenuFragment"
        app:launchSingleTop="true" />

    <action
        android:id="@+id/action_global_to_product_bots_management"
        app:destination="@id/productBotManagementFragment"
        app:launchSingleTop="true" />

    <action
        android:id="@+id/action_global_to_spaBrowserFragment"
        app:destination="@id/spaBrowserFragment" />

    <action
        android:id="@+id/action_global_to_change_currency"
        app:destination="@id/CurrencyFragment"
        app:launchSingleTop="true" />

    <action
        android:id="@+id/action_global_to_blockedUsersFragment"
        app:destination="@id/blockedUsersFragment" />

    <action
        android:id="@+id/action_global_to_linkedDevicesFragment"
        app:destination="@id/linkedDevicesFragment" />

    <action
        android:id="@+id/action_global_to_deviceDetailsFragment"
        app:destination="@id/deviceDetailsFragment" />

    <action
        android:id="@+id/action_global_to_forceReclaimFragment"
        app:destination="@id/forceReclaimFragment" />

    <action
        android:id="@+id/action_global_to_commit_to_tattoo_graph"
        app:destination="@id/commit_to_tattoo_graph" />

    <action
        android:id="@+id/action_global_to_change_language"
        app:destination="@id/LanguageFragment"
        app:launchSingleTop="true" />

    <action
        android:id="@+id/action_global_to_change_theme"
        app:destination="@id/ThemeFragment"
        app:launchSingleTop="true" />

    <action
        android:id="@+id/action_global_to_fund_graph"
        app:destination="@id/fund_graph" />

    <action
        android:id="@+id/action_global_to_scan_graph"
        app:destination="@id/scan_graph" />

    <action
        android:id="@+id/action_global_to_pairRequestBottomSheet"
        app:destination="@id/pairRequestBottomSheet" />

    <action
        android:id="@+id/action_global_to_transactionSignBottomSheet"
        app:destination="@id/transactionSignBottomSheet" />

    <action
        android:id="@+id/action_global_to_permissionPromptBottomSheet"
        app:destination="@id/permissionPromptBottomSheet" />

    <action
        android:id="@+id/action_global_to_paymentRequestBottomSheet"
        app:destination="@id/paymentRequestBottomSheet" />

    <action
        android:id="@+id/action_global_to_topUpRequestBottomSheet"
        app:destination="@id/topUpRequestBottomSheet" />

    <action
        android:id="@+id/action_global_to_resourceAllocationRequestBottomSheet"
        app:destination="@id/resourceAllocationRequestBottomSheet" />

    <action
        android:id="@+id/action_global_to_chatWithPlayersFragment"
        app:destination="@id/chatWithPlayersFragment" />

    <action
        android:id="@+id/action_global_to_evidence_video_graph"
        app:destination="@id/evidence_video_graph" />

    <action
        android:id="@+id/action_global_to_evidence_photo_graph"
        app:destination="@id/evidence_photo_graph" />

    <action
        android:id="@+id/action_global_to_evidenceDetailFragment"
        app:destination="@id/evidenceDetailFragment" />

    <action
        android:id="@+id/action_global_to_product_settings_graph"
        app:destination="@id/product_settings_graph" />

    <include app:graph="@navigation/main_graph" />
    <include app:graph="@navigation/username_graph" />
    <include app:graph="@navigation/w3s_spa_graph" />
    <include app:graph="@navigation/w3s_ended_graph" />
    <include app:graph="@navigation/send_contact_payment_graph" />
    <include app:graph="@navigation/send_enter_amount_graph" />
    <include app:graph="@navigation/backup_graph" />
    <include app:graph="@navigation/scan_graph" />
    <include app:graph="@navigation/commit_to_tattoo_graph" />
    <include app:graph="@navigation/video_game_play_graph" />
    <include app:graph="@navigation/evidence_video_graph" />
    <include app:graph="@navigation/evidence_photo_graph" />
    <include app:graph="@navigation/fund_graph" />
    <include app:graph="@navigation/product_settings_graph" />

</navigation>
